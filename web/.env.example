# Copy to .env and fill in. NEVER commit the real .env.

# --- App ---
ENVIRONMENT=production
DEBUG=false
BASE_URL=https://casagraciacartagena.com
SECRET_KEY=generate-a-long-random-string

# --- Database (you manage this) ---
# Bundled compose Postgres:
DATABASE_URL=postgresql+asyncpg://casagracia:casagracia@db:5432/casagracia
# ...or your own managed Postgres:
# DATABASE_URL=postgresql+asyncpg://USER:PASSWORD@HOST:5432/DBNAME

# --- Hotel info ---
HOTEL_PHONE=+57 300 000 0000
HOTEL_WHATSAPP=573000000000
HOTEL_EMAIL=reservas@casagraciacartagena.com

# --- Currency ---
CURRENCY=COP
USD_TO_COP=4000

# --- Wompi (get from your Wompi dashboard; use SANDBOX first) ---
WOMPI_PUBLIC_KEY=pub_test_xxxxxxxxxxxx
WOMPI_INTEGRITY_SECRET=test_integrity_xxxxxxxxxxxx
WOMPI_EVENTS_SECRET=test_events_xxxxxxxxxxxx
WOMPI_BASE_CHECKOUT=https://checkout.wompi.co/p/
WOMPI_API_BASE=https://sandbox.wompi.co/v1
# Production: WOMPI_API_BASE=https://production.wompi.co/v1

# --- Reviews moderation ---
REVIEWS_REQUIRE_APPROVAL=true
ADMIN_TOKEN=generate-a-long-random-admin-token

# --- Scaling ---
WEB_CONCURRENCY=3
RATE_LIMIT_PER_MINUTE=60
