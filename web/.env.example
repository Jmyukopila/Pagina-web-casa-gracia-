# Copy to .env and fill in. NEVER commit the real .env.

# --- App ---
ENVIRONMENT=production
DEBUG=false
BASE_URL=https://casagraciacartagena.com
SECRET_KEY=generate-a-long-random-string

# --- Database (you manage this) ---
# Bundled compose Postgres:
DATABASE_URL=postgresql+asyncpg://casagracia:casagracia@db:5432/casagracia
# ...or your own managed Postgres:
# DATABASE_URL=postgresql+asyncpg://USER:PASSWORD@HOST:5432/DBNAME

# --- Hotel info ---
HOTEL_PHONE=+57 300 000 0000
HOTEL_WHATSAPP=573000000000
HOTEL_EMAIL=reservas@casagraciacartagena.com

# --- Currency ---
CURRENCY=COP
USD_TO_COP=4000

# --- Wompi (get from your Wompi dashboard; use SANDBOX first) ---
WOMPI_PUBLIC_KEY=pub_test_xxxxxxxxxxxx
WOMPI_INTEGRITY_SECRET=test_integrity_xxxxxxxxxxxx
WOMPI_EVENTS_SECRET=test_events_xxxxxxxxxxxx
WOMPI_BASE_CHECKOUT=https://checkout.wompi.co/p/
WOMPI_API_BASE=https://sandbox.wompi.co/v1
# Production: WOMPI_API_BASE=https://production.wompi.co/v1

# --- Reviews moderation ---
REVIEWS_REQUIRE_APPROVAL=true
ADMIN_TOKEN=generate-a-long-random-admin-token

# --- Lobby PMS (channel manager) — leave blank until you have an account ---
# When LOBBY_API_TOKEN is set, the site pulls OTA reservations + rates from
# Lobby and pushes direct bookings to it. Token: Lobby > Configuraciones >
# Usuarios, Permisos y API > Ver API Token (IP allowlist optional; leave off
# for Vercel). Map each local room id to its Lobby room/product id as JSON.
LOBBY_API_TOKEN=
LOBBY_BASE_URL=https://api.lobbypms.com/api/v2
LOBBY_ROOM_MAP={"101":"","201":"","202":"","301":""}
LOBBY_SYNC_WINDOW_DAYS=90
# Shared secret for the sync endpoint. Set the same value as Vercel's CRON_SECRET
# so the scheduled job's Authorization: Bearer header is accepted.
LOBBY_SYNC_SECRET=generate-a-long-random-secret

# --- Scaling ---
WEB_CONCURRENCY=3
RATE_LIMIT_PER_MINUTE=60
