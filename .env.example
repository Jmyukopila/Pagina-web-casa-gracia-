# Casa Gracia — example environment. Copy to .env and fill in real values.
# NEVER commit the real .env (it holds secrets).

# --- App -------------------------------------------------------------------
ENVIRONMENT=production
# Public site origin, no trailing slash. Used for canonical URLs, OpenGraph
# tags, the sitemap and confirmation-email links.
BASE_URL=https://casa-gracia.vercel.app
SECRET_KEY=change-me

# --- Database (Supabase Postgres) ------------------------------------------
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/postgres

# --- Hotel contact (replace the placeholders with the real numbers) --------
# HOTEL_PHONE=+57 ...
# HOTEL_WHATSAPP=57...        # digits only, for wa.me

# --- Email / booking confirmations (optional) ------------------------------
# If unset, the app simply skips sending — bookings still work.
# Works with Gmail app-password, Resend SMTP, Mailgun, SendGrid, etc.
# SMTP_HOST=smtp.resend.com
# SMTP_PORT=587
# SMTP_USER=resend
# SMTP_PASSWORD=your-smtp-key
# SMTP_TLS=true
# MAIL_FROM=Casa Gracia <reservas@casagraciacartagena.com>

# --- Admin (read API for chatbot escalations) ------------------------------
# Set a long random value; required to call /api/admin/* (else 401).
# ADMIN_TOKEN=

# --- Chatbot LLM (free OpenAI-compatible providers, failover order) ---------
# GEMINI_API_KEY=
# GROQ_API_KEY=
# OPENROUTER_API_KEY=

# --- Wompi (deferred — leave empty until going live) -----------------------
# WOMPI_PUBLIC_KEY=
# WOMPI_INTEGRITY_SECRET=
# WOMPI_EVENTS_SECRET=
